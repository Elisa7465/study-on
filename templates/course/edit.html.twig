{% extends 'base.html.twig' %}

{% block title %}{{ course.title }} / Редактирование / StudyOn{% endblock %}

{% block body %}
    <div class="container py-4">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_course_index') }}">Курсы</a>
                </li>
                <li class="breadcrumb-item">
                    <a href="{{ path('app_course_show', {'id': course.id}) }}">{{ course.title }}</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Редактирование</li>
            </ol>
        </nav>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="mb-4">
                    <h1 class="mb-1">{{ course.title }}</h1>
                    <p class="text-body-secondary mb-0">Измени данные курса</p>
                </div>

                {{ include('course/_form.html.twig', {'button_label': 'Сохранить'}) }}

                <div class="d-flex flex-wrap gap-2 mt-3">
                    <a class="btn btn-outline-secondary" href="{{ path('app_course_show', {'id': course.id}) }}">
                        Вернуться к курсу
                    </a>
                </div>

                <div class="mt-3">
                    {{ include('course/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}