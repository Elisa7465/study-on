{% extends 'base.html.twig' %}

{% block title %}{{ course.title }} / StudyOn{% endblock %}

{% block body %}
    <div class="container py-4">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_course_index') }}">Курсы</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">{{ course.title }}</li>
            </ol>
        </nav>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                    <div>
                        <h1 class="mb-3">{{ course.title }}</h1>

                        {% if course.description %}
                            <p class="text-body-secondary mb-0">{{ course.description }}</p>
                        {% else %}
                            <p class="text-body-secondary mb-0">Описание пока не добавлено.</p>
                        {% endif %}
                    </div>

                    <div class="d-flex flex-wrap gap-2 align-self-start">
                        <a class="btn btn-outline-secondary" href="{{ path('app_course_index') }}">
                            К списку
                        </a>
                        <a class="btn btn-outline-primary" href="{{ path('app_course_edit', {'id': course.id}) }}">
                            Редактировать
                        </a>
                        <a class="btn btn-primary" href="{{ path('app_lesson_new', {'course_id': course.id}) }}">
                            Добавить урок
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h2 class="h4 mb-0">Уроки</h2>
                    <span class="badge text-bg-primary">{{ lessons|length }}</span>
                </div>

                {% if lessons is not empty %}
                    <div class="list-group list-group-flush">
                        {% for lesson in lessons %}
                            <a
                                class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                href="{{ path('app_lesson_show', {'id': lesson.id}) }}"
                            >
                                <span>{{ lesson.title }}</span>
                                <span class="badge text-bg-light border">Открыть</span>
                            </a>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="alert alert-light border mb-0">
                        Уроков пока нет.
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="mt-3">
            {{ include('course/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}