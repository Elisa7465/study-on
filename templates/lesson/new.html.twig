{% extends 'base.html.twig' %}

{% block title %}Новый урок / StudyOn{% endblock %}

{% block body %}
    <div class="container py-4">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_lesson_index') }}">Уроки</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Новый урок</li>
            </ol>
        </nav>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="mb-4">
                    <h1 class="mb-1">Создание урока</h1>
                    <p class="text-body-secondary mb-0">Заполни информацию об уроке</p>
                </div>

                {{ include('lesson/_form.html.twig', {'button_label': 'Создать урок'}) }}

                <div class="mt-3">
                    <a class="btn btn-outline-secondary" href="{{ path('app_lesson_index') }}">
                        Назад к списку
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}