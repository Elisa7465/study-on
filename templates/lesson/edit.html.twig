{% extends 'base.html.twig' %}

{% block title %}{{ lesson.title }} / {{ lesson.course.title }} / Редактирование / StudyOn{% endblock %}

{% block body %}
    <div class="container py-4">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_course_index') }}">Курсы</a>
                </li>
                <li class="breadcrumb-item">
                    <a href="{{ path('app_course_show', {'id': lesson.course.id}) }}">{{ lesson.course.title }}</a>
                </li>
                <li class="breadcrumb-item">
                    <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}">{{ lesson.title }}</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Редактирование</li>
            </ol>
        </nav>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="mb-4">
                    <h1 class="mb-2">{{ lesson.title }}</h1>
                    <p class="text-body-secondary mb-0">
                        Курс:
                        <a class="text-decoration-none" href="{{ path('app_course_show', {'id': lesson.course.id}) }}">
                            {{ lesson.course.title }}
                        </a>
                    </p>
                </div>

                {{ include('lesson/_form.html.twig', {'button_label': 'Сохранить'}) }}

                <div class="mt-3 d-flex flex-wrap gap-2">
                    <a class="btn btn-outline-secondary" href="{{ path('app_lesson_show', {'id': lesson.id}) }}">
                        Вернуться к уроку
                    </a>
                </div>

                <div class="mt-3">
                    {{ include('lesson/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}