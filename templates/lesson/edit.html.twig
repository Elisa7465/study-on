{% extends 'base.html.twig' %}

{% block title %}{{ lesson.title }} / {{ lesson.course.title }} / Редактирование / StudyOn{% endblock %}

{% block body %}
    <h1>{{ lesson.title }}</h1>

    <p>
        Курс:
        <a href="{{ path('app_course_show', {'id': lesson.course.id}) }}">{{ lesson.course.title }}</a>
    </p>

    {{ include('lesson/_form.html.twig', {'button_label': 'Сохранить'}) }}

    <p>
        <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}">Вернуться к уроку</a>
    </p>

    {{ include('lesson/_delete_form.html.twig') }}
{% endblock %}