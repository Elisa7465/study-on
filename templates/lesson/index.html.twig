{% extends 'base.html.twig' %}

{% block title %}Уроки / StudyOn{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="mb-4">
            <h1 class="mb-1">Уроки</h1>
            <p class="text-body-secondary mb-0">Все уроки по курсам</p>
        </div>

        {% if lessons is not empty %}
            <div class="card shadow-sm border-0">
                <div class="list-group list-group-flush">
                    {% for lesson in lessons %}
                        <div class="list-group-item py-3">
                            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                                <div>
                                    <div class="fw-semibold">
                                        <a class="text-decoration-none" href="{{ path('app_lesson_show', {'id': lesson.id}) }}">
                                            {{ lesson.title }}
                                        </a>
                                    </div>
                                    <div class="text-body-secondary small">
                                        Курс:
                                        <a class="text-decoration-none" href="{{ path('app_course_show', {'id': lesson.course.id}) }}">
                                            {{ lesson.course.title }}
                                        </a>
                                    </div>
                                </div>

                                <div>
                                    <a class="btn btn-outline-primary btn-sm" href="{{ path('app_lesson_show', {'id': lesson.id}) }}">
                                        Открыть
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% else %}
            <div class="alert alert-light border shadow-sm mb-0">
                Уроки пока не добавлены.
            </div>
        {% endif %}
    </div>
{% endblock %}