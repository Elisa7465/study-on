{% extends 'base.html.twig' %}

{% block title %}Уроки / StudyOn{% endblock %}

{% block body %}
    <h1>Уроки</h1>

    {% if lessons is not empty %}
        <ul>
            {% for lesson in lessons %}
                <li>
                    <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}">{{ lesson.title }}</a>
                    —
                    <a href="{{ path('app_course_show', {'id': lesson.course.id}) }}">{{ lesson.course.title }}</a>
                </li>
            {% endfor %}
        </ul>
    {% else %}
        <p>Уроки пока не добавлены.</p>
    {% endif %}
{% endblock %}