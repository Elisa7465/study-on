{% extends 'base.html.twig' %}

{% block title %}{{ lesson.title }} / {{ lesson.course.title }} / StudyOn{% endblock %}

{% block body %}
    <div class="container py-4">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_course_index') }}">Курсы</a>
                </li>
                <li class="breadcrumb-item">
                    <a href="{{ path('app_course_show', {'id': lesson.course.id}) }}">{{ lesson.course.title }}</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">{{ lesson.title }}</li>
            </ol>
        </nav>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
                    <div>
                        <h1 class="mb-2">{{ lesson.title }}</h1>
                        <p class="mb-0 text-body-secondary">
                            Курс:
                            <a class="text-decoration-none" href="{{ path('app_course_show', {'id': lesson.course.id}) }}">
                                {{ lesson.course.title }}
                            </a>
                        </p>
                    </div>

                    <div class="d-flex flex-wrap gap-2 align-self-start">
                        <a class="btn btn-outline-secondary" href="{{ path('app_course_show', {'id': lesson.course.id}) }}">
                            К курсу
                        </a>
                        <a class="btn btn-outline-primary" href="{{ path('app_lesson_edit', {'id': lesson.id}) }}">
                            Редактировать
                        </a>
                    </div>
                </div>

                {% if lesson.content %}
                    <div class="p-3 rounded bg-body-tertiary border">
                        {{ lesson.content|nl2br }}
                    </div>
                {% else %}
                    <div class="alert alert-light border mb-0">
                        Содержимое урока пока не заполнено.
                    </div>
                {% endif %}

                <div class="mt-3">
                    {{ include('lesson/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}